{
  "experiment_name": "lstm_baseline_15min",
  "forecast_horizon": "15min",
  "model_configuration": {
    "model_type": "lstm",
    "hyperparameters": {
      "hidden_size": 64,
      "num_layers": 2,
      "dropout": 0.2
    },
    "sequence_length": 12
  },
  "microgrid_configuration": {
    "mode": "islanded",
    "pv_capacity_kw": 10.0,
    "battery_capacity_kwh": 5.0,
    "battery_power_kw": 3.0,
    "inverter_capacity_kw": 12.0,
    "initial_soc_kwh": 2.5,
    "has_diesel_generator": false,
    "diesel_capacity_kw": null
  },
  "training_configuration": {
    "epochs": 50,
    "batch_size": 64,
    "learning_rate": 0.001,
    "validation_split": 0.2,
    "early_stopping_patience": 10
  },
  "data_path": "data/solar_timeseries.csv",
  "output_dir": "results"
}
